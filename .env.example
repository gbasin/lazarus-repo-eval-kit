# LLM Provider
# Which LLM provider to use. Supported: openai (default), anthropic, google, codex
# - openai/anthropic/google: direct API calls, requires an API key below
# - codex: shells out to the local `codex exec` CLI (no API key needed, uses
#   your existing Codex subscription/login). Requires Codex CLI installed.
# LLM_PROVIDER=openai

# API Keys — only the key for your chosen provider is required.
# Not needed when LLM_PROVIDER=codex.
OPENAI_API_KEY=sk-...your-key-here...
# ANTHROPIC_API_KEY=sk-ant-...your-key-here...
# GOOGLE_API_KEY=...your-key-here...

# Model override (optional)
# Override the model name used within the selected provider.
# If not set, a sensible default is used for each provider:
#   openai    → gpt-5.1
#   anthropic → claude-sonnet-4-6
#   google    → gemini-3-flash-preview
#   codex     → gpt-5.3-codex
# LLM_MODEL=gpt-5.1

# Reasoning effort for codex provider only (low/medium/high). Default: medium
# CODEX_REASONING_EFFORT=medium

# How many LLM calls to make at the same time.
# Higher values finish faster but increase the chance of hitting rate limits.
# Lower values are safer if you see "rate limit" errors. Default: 4
# LLM_CONCURRENCY=4

# How many times to retry a failed LLM call before giving up.
# Each retry waits longer than the last (exponential backoff).
# Default: 8
# LLM_MAX_RETRIES=8

# Starting wait time (in seconds) before the first retry after a failed LLM call.
# The wait doubles with each attempt: 5s → 10s → 20s → 40s … up to the retry limit.
# Increase this if you frequently hit rate limits. Default: 5.0
# LLM_BACKOFF_BASE_DELAY=5.0
